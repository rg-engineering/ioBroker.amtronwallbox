{
  "name": "iobroker.amtronwallbox",
  "version": "0.3.6",
  "description": "ioBroker Adapter for AMTRON wallboxes",
  "author": {
    "name": "René G.",
    "email": "info@rg-engineering.eu"
  },
  "homepage": "https://github.com/rg-engineering/ioBroker.amtronwallbox",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "HomeControl",
    "Smart Home",
    "home automation",
    "amtron",
    "wallbox"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rg-engineering/ioBroker.amtronwallbox.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.13.6",
    "cron": "^4.4.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2"
  },
  "main": "build/main.js",
  "bugs": {
    "url": "https://github.com/rg-engineering/ioBroker.amtronwallbox"
  },
  "files": [
    "admin/",
    "admin{,/!(i18n)/**}/flat.txt",
    "lib/",
    "!.vscode",
    "!.github",
    "!.git",
    "!.gitignore",
    "!.gitattributes",
    "!node_modules",
    "!tasks",
    "!.idea",
    "!test",
    "!typings",
    "io-package.json",
    "LICENSE",
    "!main.js",
    "build/"
  ],
  "readmeFilename": "README.md",
  "scripts": {
    "test": "npm run test:package",
    "test:package": "mocha test/package --exit",
    "test:unit": "mocha test/unit --exit",
    "test:integration": "mocha test/integration --exit",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script",
    "0-clean": "node tasks.js --0-clean",
    "1-npm": "node tasks.js --1-npm",
    "2-build": "node tasks.js --2-build",
    "3-copy": "node tasks.js --3-copy",
    "4-patch": "node tasks.js --4-patch",
    "build": "npm run build-backend  && npm pack",
    "build-backend": "tsc -p tsconfig.build.json",
    "npm": "npm i "
  }
}
